# Prevent directory listing.
Options -Indexes

# ---------------------------------------------------------------------------
# Caching for static assets (fast repeat visits). CSS/JS are versioned with
# ?v=hash, so a long immutable cache is safe; HTML revalidates hourly.
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp               "access plus 1 year"
  ExpiresByType image/jpeg               "access plus 1 year"
  ExpiresByType image/png                "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType image/x-icon             "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType font/woff                "access plus 1 year"
  ExpiresByType text/html                "access plus 1 hour"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpe?g|png|gif|svg|ico|css|js|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# Security headers.
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS is only honoured over HTTPS, so it is safe to keep here; it activates
  # once your SSL certificate is live.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # CSP: permissive on the third-party widgets (Trustindex reviews, Google
  # fonts/analytics) so nothing breaks, strict on the high-risk directives
  # (object/base/form/frame-ancestors). If you tighten it, re-check that the
  # reviews, fonts and analytics still load.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.trustindex.io https://*.trustindex.io https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.trustindex.io https://*.trustindex.io; font-src 'self' data: https://fonts.gstatic.com https://cdn.trustindex.io; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://cdn.trustindex.io https://*.trustindex.io; frame-src https://cdn.trustindex.io https://*.trustindex.io; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
</IfModule>

# 301 redirects. Same-domain rules were regenerated by auditing the old
# WordPress sitemap (248 URLs) against the current site (scripts/gen_redirects.py):
# every old URL whose slug changed points to the current page in the same
# language. Cross-domain rules send Skradin content to the sister site
# taxiskradin.hr.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS (the second condition avoids a redirect loop behind a proxy/CDN
  # that terminates SSL upstream).
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # ===== 301 redirects (regenerated from the old sitemap audit) =====
  # Aliases not present in the old sitemap
  RewriteRule ^taxi-sibenik/?$ / [R=301,L]
  RewriteRule ^transfers-2/?$ /sibenik-transfers/ [R=301,L]
  RewriteRule ^airport-zadar-transfer/?$ /airport-transfers-from-sibenik/ [R=301,L]

  # Skradin content -> sister site taxiskradin.hr
  RewriteRule ^(aci-marina-skradin-transfers)/?$ https://taxiskradin.hr/$1/ [R=301,L]
  RewriteRule ^([a-z]{2}/aci-marina-skradin-[a-z]+)/?$ https://taxiskradin.hr/$1/ [R=301,L]
  RewriteRule ^de/taxi-skradin/?$ https://taxiskradin.hr/de/ [R=301,L]
  RewriteRule ^hr/taksi-skradin/?$ https://taxiskradin.hr/hr/ [R=301,L]
  RewriteRule ^pl/taksowka-skradin/?$ https://taxiskradin.hr/pl/ [R=301,L]
  RewriteRule ^taxi-skradin/?$ https://taxiskradin.hr/ [R=301,L]

  # Old sitemap URLs whose slug changed -> current page (same language)
  RewriteRule ^airport-transfers/?$ /airport-transfers-from-sibenik/ [R=301,L]
  RewriteRule ^city-to-city-transfers/?$ /sibenik-transfers/ [R=301,L]
  RewriteRule ^day-trip-sibenik-from-split/?$ /daytrips/ [R=301,L]
  RewriteRule ^day-trip-sibenik-from-zadar/?$ /daytrips/ [R=301,L]
  RewriteRule ^de/amadria-park-sibenik-transfers/?$ /de/amadria-park-transfers/ [R=301,L]
  RewriteRule ^de/bedingungen-und-konditionen/?$ /de/agb/ [R=301,L]
  RewriteRule ^de/datenschutzbestimmungen/?$ /de/datenschutz/ [R=301,L]
  RewriteRule ^de/flughafentransfers-sibenik/?$ /de/flughafentransfers/ [R=301,L]
  RewriteRule ^de/haeufig-gestellte-fragen/?$ /de/haeufige-fragen/ [R=301,L]
  RewriteRule ^de/marina-transfers-sibenik/?$ /de/staedtetransfers/ [R=301,L]
  RewriteRule ^de/staedte-transfers-sibenik/?$ /de/staedtetransfers/ [R=301,L]
  RewriteRule ^de/tagesausflug-krka-nationalpark-split-2/?$ /de/ausflug-krka-split/ [R=301,L]
  RewriteRule ^de/tagesausflug-krka-nationalpark-split/?$ /de/ausflug-krka-split/ [R=301,L]
  RewriteRule ^de/tagesausflug-krka-nationalpark-zadar/?$ /de/ausflug-krka-zadar/ [R=301,L]
  RewriteRule ^de/tagesausflug-plitvicer-seen-sibenik/?$ /de/ausflug-plitvice-sibenik/ [R=301,L]
  RewriteRule ^de/tagesausflug-plitvicer-seen-split/?$ /de/ausflug-plitvice-split/ [R=301,L]
  RewriteRule ^de/tagesausflug-sibenik-ab-split/?$ /de/tagesausfluege/ [R=301,L]
  RewriteRule ^de/tagesausflug-sibenik-ab-zadar/?$ /de/tagesausfluege/ [R=301,L]
  RewriteRule ^de/taxi-dubrovnik-nach-sibenik/?$ /de/taxi-dubrovnik-sibenik/ [R=301,L]
  RewriteRule ^de/taxi-dubrovnik-nach-zadar/?$ /de/taxi-dubrovnik-zadar/ [R=301,L]
  RewriteRule ^de/taxi-dubrovnik-zum-flughafen-zadar/?$ /de/taxi-dubrovnik-flughafen-zadar/ [R=301,L]
  RewriteRule ^de/taxi-flughafen-split-nach-sibenik/?$ /de/taxi-flughafen-split-sibenik/ [R=301,L]
