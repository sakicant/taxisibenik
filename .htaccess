# Prevent directory listing.
Options -Indexes

# ---------------------------------------------------------------------------
# 301 redirects: migrated from the old WordPress redirect plugin, plus URL
# changes from the rebuild. Same domain, so each rule is old path -> new path.
# Format:  RewriteRule ^OLD-PATH/?$ /NEW-PATH/ [R=301,L]
# (no leading slash on the match side; the trailing /? makes the slash optional)
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- New URL changes from the rebuild ---
  RewriteRule ^airport-transfers/?$ /airport-transfers-from-sibenik/ [R=301,L]
  RewriteRule ^vodice-transfers/?$ /taxi-vodice/ [R=301,L]
  RewriteRule ^transfers/?$ /sibenik-transfers/ [R=301,L]
  RewriteRule ^transfers-2/?$ /sibenik-transfers/ [R=301,L]
  RewriteRule ^taxi-sibenik/?$ / [R=301,L]
  RewriteRule ^airport-zadar-transfer/?$ /airport-transfers-from-sibenik/ [R=301,L]
  # --- Legacy redirects to sister site taxiskradin.hr (17) ---
  RewriteRule ^taxi-vodice-skradin/?$ https://taxiskradin.hr/taxi-vodice-to-skradin/ [R=301,L]
  RewriteRule ^taxi-skradin-vodice/?$ https://taxiskradin.hr/taxi-skradin-to-vodice/ [R=301,L]
  RewriteRule ^taxi-zadar-skradin/?$ https://taxiskradin.hr/taxi-zadar-to-skradin/ [R=301,L]
  RewriteRule ^taxi-skradin-zadar/?$ https://taxiskradin.hr/taxi-skradin-to-zadar/ [R=301,L]
  RewriteRule ^taxi-skradin-zagreb/?$ https://taxiskradin.hr/taxi-skradin-to-zagreb/ [R=301,L]
  RewriteRule ^taxi-zagreb-skradin/?$ https://taxiskradin.hr/taxi-zagreb-to-skradin/ [R=301,L]
  RewriteRule ^taxi-split-skradin/?$ https://taxiskradin.hr/taxi-split-to-skradin/ [R=301,L]
  RewriteRule ^taxi-skradin-split/?$ https://taxiskradin.hr/taxi-skradin-to-split/ [R=301,L]
  RewriteRule ^taxi-skradin-sibenik/?$ https://taxiskradin.hr/taxi-skradin-to-sibenik/ [R=301,L]
  RewriteRule ^taxi-skradin-primosten/?$ https://taxiskradin.hr/taxi-skradin-to-primosten/ [R=301,L]
  RewriteRule ^taxi-primosten-skradin/?$ https://taxiskradin.hr/taxi-primosten-to-skradin/ [R=301,L]
  RewriteRule ^taxi-skradin-dubrovnik/?$ https://taxiskradin.hr/taxi-skradin-to-dubrovnik/ [R=301,L]
  RewriteRule ^taxi-dubrovnik-skradin/?$ https://taxiskradin.hr/taxi-dubrovnik-to-skradin/ [R=301,L]
  RewriteRule ^taxi-skradin-zadar-airport/?$ https://taxiskradin.hr/taxi-skradin-to-zadar-airport/ [R=301,L]
  RewriteRule ^taxi-zadar-airport-skradin/?$ https://taxiskradin.hr/taxi-zadar-airport-to-skradin/ [R=301,L]
  RewriteRule ^taxi-split-airport-skradin/?$ https://taxiskradin.hr/taxi-split-airport-to-skradin/ [R=301,L]
  RewriteRule ^taxi-skradin-split-airport/?$ https://taxiskradin.hr/taxi-skradin-to-split-airport/ [R=301,L]
  # --- Legacy same-domain redirects, old slug to translated slug (64) ---
  RewriteRule ^pl/o/?$ /pl/about/ [R=301,L]
  RewriteRule ^de/uber/?$ /de/about/ [R=301,L]
  RewriteRule ^hr/o-nama/?$ /hr/about/ [R=301,L]
  RewriteRule ^de/uberweisungen/?$ /de/transfers-sibenik/ [R=301,L]
  RewriteRule ^hr/prijenosi/?$ /hr/transferi-sibenik/ [R=301,L]
  RewriteRule ^hr/tisno-prijenosi/?$ /hr/tisno-transferi/ [R=301,L]
  RewriteRule ^hr/taksi-zadar-sibenik/?$ /hr/taxi-zadar-do-sibenika/ [R=301,L]
  RewriteRule ^pl/taxi-zadar-lotnisko-dubrownik/?$ /pl/taksowka-lotnisko-zadar-dubrownik/ [R=301,L]
  RewriteRule ^hr/taksi-vodic-zracna-luka-zadar/?$ /hr/taxi-vodice-do-zracne-luke-zadar/ [R=301,L]
  RewriteRule ^hr/taksi-split-zracna-luka-zadar/?$ /hr/taxi-split-do-zracne-luke-zadar/ [R=301,L]
  RewriteRule ^pl/taxi-split-to-vodice/?$ /pl/taksowka-split-vodice/ [R=301,L]
  RewriteRule ^de/taxi-split-sibenik/?$ /de/taxi-split-nach-sibenik/ [R=301,L]
  RewriteRule ^pl/taxi-split-lotnisko-sibenik/?$ /pl/taksowka-lotnisko-split-sibenik/ [R=301,L]
  RewriteRule ^de/taxi-split-flughafen-sibenik/?$ /de/taxi-flughafen-split-nach-sibenik/ [R=301,L]
  RewriteRule ^pl/taxi-skradin/?$ /pl/taksowka-skradin/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-zagrzeb/?$ /pl/taksowka-sibenik-zagrzeb/ [R=301,L]
  RewriteRule ^de/taxi-sibenik-zagreb/?$ /de/taxi-sibenik-nach-zagreb/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-zagreb/?$ /hr/taxi-sibenik-do-zagreba/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-zadar-lotnisko/?$ /pl/taksowka-sibenik-lotnisko-zadar/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-zadar-aerodrom/?$ /hr/taxi-sibenik-do-zracne-luke-zadar/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-zadar/?$ /pl/taksowka-sibenik-zadar/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-zadar/?$ /hr/taxi-sibenik-do-zadra/ [R=301,L]
  RewriteRule ^de/taxi-sibenik-vodice/?$ /de/taxi-sibenik-nach-vodice/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-vocice/?$ /hr/taxi-sibenik-do-vodica/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-do-trogiru/?$ /pl/taksowka-sibenik-trogir/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-za-trogir/?$ /hr/taxi-sibenik-do-trogira/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-split/?$ /pl/taksowka-sibenik-split/ [R=301,L]
  RewriteRule ^de/taxi-sibenik-split/?$ /de/taxi-sibenik-nach-split/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-split/?$ /hr/taxi-sibenik-do-splita/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-skradin/?$ /pl/taksowka-sibenik-skradin/ [R=301,L]
  RewriteRule ^de/taxi-sibenik-skradin/?$ /de/taxi-sibenik-nach-skradin/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-skradin/?$ /hr/taxi-sibenik-do-skradina/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-primosten/?$ /pl/taksowka-sibenik-primosten/ [R=301,L]
  RewriteRule ^de/taxi-sibenik-primosten/?$ /de/taxi-sibenik-nach-primosten/ [R=301,L]
  RewriteRule ^pl/taxi-sibenik-dubrovnik/?$ /pl/taksowka-sibenik-dubrownik/ [R=301,L]
  RewriteRule ^de/taxi-sibenik-dubrovnik/?$ /de/taxi-sibenik-nach-dubrovnik/ [R=301,L]
  RewriteRule ^hr/taksi-sibenik-dubrovnik/?$ /hr/taxi-sibenik-do-dubrovnika/ [R=301,L]
  RewriteRule ^hr/taksi-makarska-za-sibenik/?$ /hr/taxi-makarska-do-sibenika/ [R=301,L]
  RewriteRule ^de/taxi-dubrovnik-zadar-flughafen/?$ /de/taxi-dubrovnik-zum-flughafen-zadar/ [R=301,L]
  RewriteRule ^hr/taksi-dubrovnik-zadar/?$ /hr/taxi-dubrovnik-do-zadra/ [R=301,L]
  RewriteRule ^pl/transfery-do-przystani/?$ /pl/transfery-marinowe-sibenik/ [R=301,L]
  RewriteRule ^de/hafentransfers/?$ /de/marina-transfers-sibenik/ [R=301,L]
  RewriteRule ^de/haufig-gestellte-fragen/?$ /de/haeufig-gestellte-fragen/ [R=301,L]
  RewriteRule ^de/tagesausfluge/?$ /de/tagesausfluege/ [R=301,L]
  RewriteRule ^hr/dnevni-izleti/?$ /hr/izleti/ [R=301,L]
  RewriteRule ^pl/jednodniowa-wycieczka-park-narodowy-jezior-plitwickich-split/?$ /pl/wycieczka-jeziora-plitwickie-split/ [R=301,L]
  RewriteRule ^de/tagesausflug-nationalpark-plitvicer-seen-split/?$ /de/tagesausflug-plitvicer-seen-split/ [R=301,L]
  RewriteRule ^hr/dnevni-izlet-nacionalni-park-plitvicke-jezere-splitska/?$ /hr/izlet-plitvicka-jezera-split/ [R=301,L]
  RewriteRule ^pl/jednodniowa-wycieczka-park-narodowy-jezior-plitwickich-sibenik/?$ /pl/wycieczka-jeziora-plitwickie-sibenik/ [R=301,L]
  RewriteRule ^de/tagesausflug-plitvicer-seen-nationalpark-sibenik/?$ /de/tagesausflug-plitvicer-seen-sibenik/ [R=301,L]
  RewriteRule ^hr/jednodnevni-izlet-u-nacionalni-park-plitvicke-jezere-iz-sibenika/?$ /hr/izlet-plitvicka-jezera-sibenik/ [R=301,L]
  RewriteRule ^pl/jednodniowa-wycieczka-park-narodowy-krka-zadar/?$ /pl/wycieczka-krka-park-narodowy-zadar/ [R=301,L]
  RewriteRule ^hr/dnevni-izlet-nacionalni-park-krka-zadar/?$ /hr/izlet-krka-nacionalni-park-zadar/ [R=301,L]
  RewriteRule ^pl/jednodniowa-wycieczka-park-narodowy-krka-split/?$ /pl/wycieczka-krka-park-narodowy-split/ [R=301,L]
  RewriteRule ^hr/dnevni-izlet-nacionalni-park-krka-splitska/?$ /hr/izlet-krka-nacionalni-park-split/ [R=301,L]
  RewriteRule ^pl/jednodniowa-wycieczka-park-narodowy-krka-sibenik/?$ /pl/wycieczka-krka-park-narodowy-sibenik/ [R=301,L]
  RewriteRule ^hr/dnevni-izlet-nacionalni-park-krka-sibenik/?$ /hr/izlet-krka-nacionalni-park-sibenik/ [R=301,L]
  RewriteRule ^pl/transfery-miedzy-miastami/?$ /pl/transfery-miedzymiastowe-sibenik/ [R=301,L]
  RewriteRule ^de/transfers-von-stadt-zu-stadt/?$ /de/staedte-transfers-sibenik/ [R=301,L]
  RewriteRule ^hr/prijevoz-od-grada-do-grada/?$ /hr/medjugradski-transferi-sibenik/ [R=301,L]
  RewriteRule ^pl/transfery-lotniskowe/?$ /pl/transfery-lotniskowe-sibenik/ [R=301,L]
  RewriteRule ^de/flughafentransfers/?$ /de/flughafentransfers-sibenik/ [R=301,L]
  RewriteRule ^hr/prijevoz-do-zracne-luke/?$ /aerodromski-transferi-sibenik [R=301,L]
  RewriteRule ^taxi-zagreb-airport-sibenik/?$ /taxi-zagreb-sibenik [R=301,L]
  # --- Legacy redirects that pointed to a WP post ID, remapped to current URL (7) ---
  RewriteRule ^daytrips/?$ /daytrips/ [R=301,L]
  RewriteRule ^day-trip-zadar-krka/?$ /day-trip-krka-national-park-zadar/ [R=301,L]
  RewriteRule ^taxi-zadar-airport-to-vodice/?$ /taxi-zadar-airport-vodice/ [R=301,L]
  RewriteRule ^taxi-vodice-to-split-airport/?$ /taxi-vodice-split-airport/ [R=301,L]
  RewriteRule ^taxi-sibenik-to-vodice/?$ /taxi-sibenik-vodice/ [R=301,L]
  RewriteRule ^taxi-transfer-sibenik-to-split-airport/?$ /taxi-sibenik-split-airport/ [R=301,L]
  RewriteRule ^taxi-transfer-split-airport-to-sibenik/?$ /taxi-split-airport-sibenik/ [R=301,L]
</IfModule>

# Never allow the browser to fetch credentials, raw config, or the SQL schema,
# even if PHP is ever misconfigured.
<FilesMatch "^(config\.php|config\.sample\.php|db\.php|schema\.sql)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
