# Admin area. Everything here is gated by the HTTP Basic Auth check in auth.php.
#
# Every directive below is wrapped in an <IfModule> guard. An unguarded
# directive makes Apache return 500 for this whole folder when the host does
# not permit it. "Options -Indexes" was the offender here: it needs
# AllowOverride Options, which this shared host does not grant. Directory
# listing is not a risk anyway, because index.php exists in this folder.

# Pass the HTTP Authorization header through to PHP on hosts (CGI/FastCGI) that
# don't do it by default, so the Basic Auth gate can read the credentials.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule mod_setenvif.c>
  SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Keep this folder out of search engines regardless of robots.txt.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
