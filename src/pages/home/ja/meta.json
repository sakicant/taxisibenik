      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "シベニクでタクシーを予約するにはどうすればよいですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "+385 99 447 1013 にお電話いただくか、WhatsApp でメッセージをお送りいただくか、メールをお送りください。アントニオはお迎えの場所、行き先、ご希望のお迎え時刻または到着時刻をお伺いします。"
          }
        },
        {
          "@type": "Question",
          "name": "どのくらい前に予約すればよいですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "営業時間内であれば直前のご依頼もお受けしますが、事前にご予約いただくと確実にご利用いただけます。"
          }
        },
        {
          "@type": "Question",
          "name": "「固定料金」とは何ですか。何が含まれますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "固定料金には輸送、燃料、通行料、荷物のお手伝いが含まれます。隠れた費用はありません。追加の立ち寄りや長い待機は追加料金となる場合がありますが、事前にお伝えします。"
          }
        },
        {
          "@type": "Question",
          "name": "前払金は必要ですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい。ご予約の確定には20%の前払金（最低20ユーロ）が必要です。20ユーロ以下の乗車は全額前払いとなります。前払金は銀行振込（SEPA）またはカードでお支払いいただけ、残額は送迎当日に精算します。"
          }
        },
        {
          "@type": "Question",
          "name": "車内でカード払いはできますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい、カードやその他の非接触の支払い方法をご利用いただけます。"
          }
        },
        {
          "@type": "Question",
          "name": "シベニクの病院へのお迎えは可能ですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい。アントニオはシベニク総合病院への送り迎えを行っており、病院の敷地内まで車で入ることが認められていますので、駐車場から長く歩く必要はありません。"
          }
        },
        {
          "@type": "Question",
          "name": "島へ行くフェリー乗り場まで送ってもらえますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい。アントニオは Zlarin、Prvić、Kaprije、Žirje 行きのシベニクのフェリーおよびカタマラン港、そして Obonjan 行きの船着き場への送り迎えを行っています。"
          }
        },
        {
          "@type": "Question",
          "name": "シベニクのホテル、バスターミナル、鉄道駅からのお迎えは可能ですか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい。アントニオは地元のすべてのホテル、バスターミナル、シベニク駅と Perković 駅、フェリー港に対応しており、荷物のお手伝いと、ご希望に応じて名前を書いたボードもご用意します。"
          }
        },
        {
          "@type": "Question",
          "name": "フライトが遅延した場合はどうなりますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "フライトの到着はリアルタイムで監視し、追加料金なしでお迎え時刻を自動的に調整します。"
          }
        },
        {
          "@type": "Question",
          "name": "キャンセルが必要になった場合はどうなりますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "キャンセルはメールにて書面でお願いします。ご予約の72時間より前であれば、銀行振込は全額返金、カードは10ユーロの手数料を差し引いた全額返金となります。72時間以内のキャンセルおよび無連絡の不参加は返金いたしかねます。日程の変更はいつでも無料です。"
          }
        },
        {
          "@type": "Question",
          "name": "大人数のグループにも対応できますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Škoda Superb は最大4名までご乗車いただけます。それより大人数の場合は、厳選した地元のパートナーを通じて手配いたします。"
          }
        },
        {
          "@type": "Question",
          "name": "チャイルドシートはありますか？",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "はい、チャイルドシートとブースターシートをご希望に応じてご用意します。"
          }
        }
      ]
    }
